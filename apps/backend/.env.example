# ==========================================
# Axis Predict - Backend / Agent / Deployment
# ==========================================

# HTTP server
PORT=3001

# Sui RPC
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_CLOCK_OBJECT_ID=0x6

# Wallets
# Backend agent wallet: owns the PredictManager and receives AgentCap
AGENT_PRIVATE_KEY=
# Deployer wallet: publishes sc/defai_agent and initializes the shared vault
DEPLOYER_PRIVATE_KEY=

# Optional LLM integration for later strategy reasoning
OPENROUTER_API_KEY=

# Optional: specify a custom model for strategy reasoning (defaults to gpt-4o-mini if not set)
OPENROUTER_MODEL=openai/gpt-4o-mini

# DeepBook Predict testnet defaults
PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com
DEEPBOOK_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
DEEPBOOK_PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
SUI_DUSDC_COIN_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC

# Agent-owned PredictManager shared object
DEEPBOOK_MANAGER_ID=

# Axis vault deployment outputs
SUI_PACKAGE_ID=
SUI_VAULT_ID=
SUI_AGENT_CAP_ID=
