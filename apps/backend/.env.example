# ==========================================
# Axis Predict - Backend & Agent Configuration
# ==========================================

# SUI Network Mode (mainnet, testnet, devnet, localnet)
SUI_NETWORK=testnet

# SUI RPC Endpoint
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Port for Express.js server
PORT=3001

# ==========================================
# AI Agent Credentials (Private Key)
# ==========================================
# Bech32 private key format (suiprivkey...) or Raw hex format
# This address must hold the AgentCap object to execute strategies.
AGENT_PRIVATE_KEY=

# OpenRouter API Key (GPT models / Volatility Analysis)
OPENROUTER_API_KEY=

# ==========================================
# Deployed Sui Move Smart Contract Addresses
# ==========================================
# Deployed Package ID of sc/defai_agent
SUI_PACKAGE_ID=

# Shared Object ID for Axis Vault (axis_vault::Vault)
SUI_VAULT_ID=

# Agent Capability Object ID (axis_vault::AgentCap) held by the Agent Address
SUI_AGENT_CAP_ID=

# Coin Type for dUSDC asset on Sui Testnet
# (Mysten official testnet dUSDC faucet asset)
SUI_DUSDC_COIN_TYPE=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138::dusdc::DUSDC

# Coin Type for pUSDC vault share asset ($pUSDC)
# format: <SUI_PACKAGE_ID>::pusdc::PUSDC
SUI_PUSDC_SHARE_TYPE=
